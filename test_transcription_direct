def test_local_file_transcription():
    """Test transcription with a local file if available"""
    print("\n📁 Testing Local File Transcription")
    print("=" * 38)
    
    # Look for audio files in uploads directory
    uploads_dir = Path('/app/uploads' if os.path.exists('/app/uploads') else './uploads')
    
    if not uploads_dir.exists():
        print("⚠️ No uploads directory found")
        return True
    
    # Find audio files
    audio_extensions = ['.webm', '.wav', '.mp3', '.m4a', '.ogg']
    audio_files = []
    
    for ext in audio_extensions:
        audio_files.extend(uploads_dir.glob(f'*{ext}'))
    
    if not audio_files:
        print("ℹ️ No audio files found in uploads directory")
        return True
    
    # Use the most recent file
    test_file = sorted(audio_files, key=lambda x: x.stat().st_mtime)[-1]
    print(f"🎵 Found test file: {test_file.name}")
    print(f"📊 File size: {test_file.stat().st_size} bytes")
    
    try:
        import assemblyai as aai
        
        # Set API key
        aai.settings.api_key = "d8a38013ebce49d88d0579ce2d28d0d2"
        
        # Configure transcription
        config = aai.TranscriptionConfig(
            speech_model=aai.SpeechModel.best,
            punctuate=True,
            format_text=True
        )
        
        transcriber = aai.Transcriber(config=config)
        
        print(f"🔄 Transcribing {test_file.name}...")
        transcript = transcriber.transcribe(str(test_file))
        
        print(f"📡 Status: {transcript.status}")
        
        if transcript.status == "error":
            print(f"❌ Error: {transcript.error}")
            return False
        
        print(f"✅ Local transcription successful!")
        print(f"📝 Text: {transcript.text[:200] if transcript.text else 'No text'}...")
        print(f"🎯 Confidence: {getattr(transcript, 'confidence', 'N/A')}")
        print(f"📊 Words: {len(transcript.text.split()) if transcript.text else 0}")
        
        return True
        
    except Exception as e:
        print(f"❌ Local file test failed: {e}")
        import traceback
        traceback.print_exc()
        return False

