def test_redis_session():
    """Test Redis session operations"""
    print("\n🔴 Testing Redis Session Operations")
    print("=" * 36)
    
    try:
        from core.redis_client import RedisClient
        
        # Create Redis client
        redis_client = RedisClient(
            host=os.getenv('REDIS_HOST', 'localhost'),
            port=int(os.getenv('REDIS_PORT', '6379')),
            password=os.getenv('REDIS_PASSWORD'),
            db=0
        )
        
        # Test ping
        if not redis_client.ping():
            print("❌ Redis ping failed")
            return False
        
        print("✅ Redis connection OK")
        
        # Test session operations
        test_session_id = "direct-test-session"
        
        # Set test data
        test_data = {
            'status': 'completed',
            'transcript_text': 'This is a test transcript',
            'transcript_confidence': 0.95,
            'transcript_words': 5
        }
        
        redis_client.set_session_status(test_session_id, test_data)
        print("✅ Session status set")
        
        # Retrieve data
        retrieved = redis_client.get_session_status(test_session_id)
        if retrieved:
            print("✅ Session status retrieved")
            print(f"📊 Status: {retrieved.get('status')}")
            print(f"📝 Text: {retrieved.get('transcript_text')}")
            return True
        else:
            print("❌ Session status retrieval failed")
            return False
        
    except Exception as e:
        print(f"❌ Redis test failed: {e}")
        import traceback
        traceback.print_exc()
        return False

def main():
    """Run all direct tests"""
    print("🧪 Direct Transcription Test Suite")
    print("=" * 50)
    
    tests = [
        ("AssemblyAI Direct", test_assemblyai_direct),
        ("Worker Import", test_worker_import),
        ("Redis Session", test_redis_session),
        ("Local File Transcription", test_local_file_transcription),
    ]
    
    passed = 0
    for test_name, test_func in tests:
        print(f"\n{'='*50}")
        print(f"🧪 Running: {test_name}")
        print('='*50)
        
        try:
            if test_func():
                passed += 1
                print(f"✅ {test_name} PASSED")
            else:
                print(f"❌ {test_name} FAILED")
        except Exception as e:
            print(f"💥 {test_name} CRASHED: {e}")
    
    print(f"\n{'='*50}")
    print(f"📊 Results: {passed}/{len(tests)} tests passed")
    print('='*50)
    
    if passed >= 3:
        print("🎉 Transcription system is working!")
        
        # Show next steps
        print("\n📋 Troubleshooting Steps:")
        print("1. Check worker logs: docker logs audio_transcription_worker")
        print("2. Check if worker is processing: docker exec audio_transcription_worker ps aux")
        print("3. Test with fresh recording in the web interface")
        print("4. Check Redis data: docker exec audio_transcription_worker python -c \"from core.redis_client import RedisClient; import os; r=RedisClient(host=os.getenv('REDIS_HOST'), port=int(os.getenv('REDIS_PORT')), password=os.getenv('REDIS_PASSWORD')); print('Redis keys:', r.client.keys('*'))\"")
        
    else:
        print("⚠️ Issues detected. Fix the failing tests above.")
    
    return 0 if passed >= 3 else 1

if __name__ == "__main__":
    sys.exit(main())